{
  "manifest_version": 3,
  "name": "Copy as Markdown",
  "version": "1.0.0",
  "description": "Convert any web content to clean Markdown in one click. Feed your AI agents and chatbots better context, use fewer tokens, and cut API costs.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "clipboardWrite",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["turndown.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "copy-as-markdown": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Copy selected content as Markdown"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "copy-as-markdown@extension",
      "strict_min_version": "109.0"
    }
  }
}
